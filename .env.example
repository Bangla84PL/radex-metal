# Radex Metal - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ==============================================================================
# EMAIL SERVICE CONFIGURATION (Choose ONE option)
# ==============================================================================

# -------------------------
# OPTION 1: Resend (Recommended)
# -------------------------
# Modern email API with generous free tier (100 emails/day)
# Sign up: https://resend.com
# Documentation: https://resend.com/docs

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# -------------------------
# OPTION 2: Nodemailer + Gmail SMTP
# -------------------------
# Use Gmail's SMTP server (free, requires App Password)
# Setup guide: https://support.google.com/accounts/answer/185833

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=radexmetal.com@gmail.com
# SMTP_PASSWORD=your_16_character_app_password_here

# -------------------------
# OPTION 3: SendGrid
# -------------------------
# Reliable email service with analytics
# Sign up: https://sendgrid.com
# Free tier: 100 emails/day

# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# EMAIL RECIPIENT
# ==============================================================================

# Where contact form submissions should be sent
CONTACT_EMAIL=radexmetal.com@gmail.com

# Optional: CC email address
# CONTACT_EMAIL_CC=radexmetal.pl@gmail.com

# ==============================================================================
# SITE CONFIGURATION
# ==============================================================================

# Production URL (used for canonical URLs, OG tags, etc.)
NEXT_PUBLIC_SITE_URL=https://radexmetal.com

# Site name (used in email templates, meta tags)
NEXT_PUBLIC_SITE_NAME=Radex Metal

# ==============================================================================
# GOOGLE MAPS (Optional - only if using Maps API instead of iframe)
# ==============================================================================

# If you decide to use Google Maps JavaScript API instead of iframe embed
# Get API key: https://developers.google.com/maps/documentation/javascript/get-api-key

# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ==============================================================================
# PHASE 2: ANALYTICS (Not needed for MVP)
# ==============================================================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
# Format: G-XXXXXXXXXX

# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity Project ID
# Get from: https://clarity.microsoft.com/
# Format: alphanumeric string

# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxxxxxx

# ==============================================================================
# PHASE 2: LIVE CHAT (Not needed for MVP)
# ==============================================================================

# Tawk.to Property ID and Widget ID
# Get from: https://www.tawk.to/

# NEXT_PUBLIC_TAWK_PROPERTY_ID=xxxxxxxxxxxxxx
# NEXT_PUBLIC_TAWK_WIDGET_ID=xxxxxxxxxxxxxx

# ==============================================================================
# PHASE 3: DATABASE (Not needed for MVP)
# ==============================================================================

# Supabase Configuration
# Get from: https://supabase.com/dashboard/project/_/settings/api

# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==============================================================================
# PHASE 3: AUTHENTICATION (Not needed for MVP)
# ==============================================================================

# NextAuth.js Configuration
# Get from: https://next-auth.js.org/configuration/options

# NEXTAUTH_URL=https://radexmetal.com
# NEXTAUTH_SECRET=your_super_secret_random_string_min_32_characters_long

# ==============================================================================
# DEVELOPMENT (Optional)
# ==============================================================================

# Node environment (automatically set by Vercel)
# NODE_ENV=development

# Vercel environment (automatically set by Vercel)
# VERCEL_ENV=production

# ==============================================================================
# NOTES
# ==============================================================================

# MVP Requirements (Phase 1):
# - One email service (RESEND_API_KEY recommended)
# - CONTACT_EMAIL (required)
# - NEXT_PUBLIC_SITE_URL (required)

# All Phase 2 and Phase 3 variables can be added later.

# Security Reminders:
# 1. Never commit .env.local to Git
# 2. Use Vercel dashboard to set production environment variables
# 3. Rotate API keys regularly
# 4. Use different credentials for development and production

# ==============================================================================
# QUICK START GUIDE
# ==============================================================================

# 1. Copy this file:
#    cp .env.example .env.local

# 2. Choose email service (Resend recommended):
#    - Go to https://resend.com and create account
#    - Generate API key
#    - Paste API key in RESEND_API_KEY

# 3. Set recipient email:
#    CONTACT_EMAIL=radexmetal.com@gmail.com

# 4. Set site URL:
#    NEXT_PUBLIC_SITE_URL=http://localhost:3000 (development)
#    NEXT_PUBLIC_SITE_URL=https://radexmetal.com (production)

# 5. Test email sending:
#    npm run dev
#    Fill out contact form
#    Check radexmetal.com@gmail.com inbox

# ==============================================================================
